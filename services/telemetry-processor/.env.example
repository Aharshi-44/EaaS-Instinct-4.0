APP_NAME=telemetry-processor
DEBUG=false
LOG_LEVEL=info

# Server
HOST=0.0.0.0
PORT=3006

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/energix_telemetry

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=telemetry-processor
KAFKA_TELEMETRY_TOPIC=energy-telemetry

# Aggregation
AGGREGATION_INTERVAL_MINUTES=5
